# Supabase — from the abhyas Supabase project dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # Server-side only — never expose to client

# Encryption — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=                     # 32 bytes hex — master key for AES-256-GCM
                                    # NEVER commit this. NEVER log it. Loss = all stored keys unrecoverable.

# Langfuse — from cloud.langfuse.com project settings
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASEURL=https://cloud.langfuse.com

# App URL — used for OAuth redirects
NEXT_PUBLIC_APP_URL=http://localhost:3000   # change to https://abhyas.tapovan.ai in Vercel

# GitHub OAuth is configured in Supabase Auth dashboard (not directly here)
# Callback URL registered in GitHub OAuth App: https://abhyas.tapovan.ai/auth/callback
